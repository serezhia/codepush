# Self-hosted Shorebird Code Push — Environment Variables
# Copy this file to .env and modify as needed.

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=shorebird
POSTGRES_PASSWORD=shorebird_secret
POSTGRES_DB=shorebird

# ─── Server ───────────────────────────────────────────────────
DATABASE_URL=postgres://shorebird:shorebird_secret@postgres:5432/shorebird
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
SERVER_URL=http://localhost:8080
PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT issuer — must match AUTH_SERVICE_URL in Shorebird CLI.
# The CLI validates that JWTs are issued by this URL.
AUTH_ISSUER=http://localhost:8080/auth

# ─── Shorebird CLI Environment Variables ──────────────────────
# Set these on the MACHINE running the CLI (not in Docker):
#
#   export SHOREBIRD_HOSTED_URL=http://localhost:8080
#   export AUTH_SERVICE_URL=http://localhost:8080/auth
#   export SHOREBIRD_JWT_ISSUER=http://localhost:8080/auth
#
# SHOREBIRD_JWT_ISSUER must match AUTH_ISSUER above.
# Without it, token refresh fails after the 15-minute access token expires.

# ─── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=artifacts
# Public endpoint for download URLs exposed to devices/browsers.
# Use the host-facing port (9000 mapped to host).
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
