# Self-hosted Shorebird Code Push — Environment Variables
# Copy this file to .env and modify as needed.

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=shorebird
POSTGRES_PASSWORD=shorebird_secret
POSTGRES_DB=shorebird

# ─── Server ───────────────────────────────────────────────────
DATABASE_URL=postgres://shorebird:shorebird_secret@postgres:5432/shorebird
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
# Nginx proxy listens on port 80. Use your LAN IP so the Android emulator
# and physical devices can reach the server.
# Android emulator: set SHOREBIRD_HOSTED_URL=http://10.0.2.2
# LAN / physical device: set SHOREBIRD_HOSTED_URL=http://192.168.1.139
SERVER_URL=http://192.168.1.139
PORT=8080
CORS_ORIGINS=http://localhost,http://192.168.1.139,http://10.0.2.2

# JWT issuer — must match AUTH_SERVICE_URL in Shorebird CLI.
AUTH_ISSUER=http://192.168.1.139/auth

# ─── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=artifacts
# Downloads are proxied through the server, so no public MinIO endpoint needed.
MINIO_PUBLIC_ENDPOINT=
